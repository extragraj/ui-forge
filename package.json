{
  "name": "ui-forge",
  "version": "1.6.0",
  "description": "Production Next.js component generator for Claude Code and AI coding assistants. Standalone for any Next.js project or companion mode for StackShift-paired Sanity sites.",
  "type": "module",
  "bin": {
    "ui-forge": "bin/cli.mjs"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "scan": "node scripts/scan.js",
    "generate": "node scripts/invoke.js",
    "build": "pnpm --filter ui-forge-cli build",
    "sync-version": "node scripts/sync-version.mjs",
    "prepack": "pnpm sync-version && pnpm build",
    "test": "node tests/run-cli-tests.mjs"
  },
  "keywords": [
    "nextjs",
    "component",
    "generator",
    "ai",
    "claude",
    "skill",
    "tsx",
    "tailwind",
    "react",
    "vercel",
    "shadcn",
    "ui-components"
  ],
  "author": "Garry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/extragraj/ui-forge"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "cli/dist",
    "scripts",
    "commands",
    "references",
    "themes",
    "packages/variant-contract",
    "skill.version",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
